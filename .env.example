# Per master prompt §12 — app env vars.
#
# Android emulator can't reach the host's localhost; use http://10.0.2.2:4000
# instead when running on an emulator.

API_BASE_URL=http://localhost:4000
SOCKET_URL=http://localhost:4000

# Get from Google Cloud Console (enable Places API + Directions API).
# Restrict the key to your iOS bundle id + Android package name + SHA fingerprint.
GOOGLE_MAPS_API_KEY=
